<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="d-flex position-relative">
  <%- include('partials/sidebar') %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <div class="main-content flex-grow-1 p-4">
    <h4 class="mb-4"><i class="bi bi-file-earmark-pdf me-2"></i>Documents</h4>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <form action="/documents/upload" method="POST" enctype="multipart/form-data" class="row g-2 align-items-end">
          <div class="col-md-6">
            <label class="form-label fw-bold">Upload PDF File</label>
            <input type="file" name="file" class="form-control" accept=".pdf" required>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-danger w-100"><i class="bi bi-cloud-upload me-1"></i> Upload</button>
          </div>
        </form>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <% if (documents.length === 0) { %>
          <p class="text-muted text-center py-4 mb-0">ไม่มีเอกสาร PDF</p>
        <% } else { %>
          <div class="row g-3">
            <% documents.forEach(function(doc) { %>
              <div class="col-md-3 col-sm-4 col-6">
                <div class="card h-100 border-light shadow-sm">
                  <div class="card-body text-center d-flex flex-column align-items-center">
                    <a href="/documents/view/<%= doc.id %>" class="text-decoration-none">
                      <i class="bi bi-file-earmark-pdf-fill text-danger" style="font-size:3rem;"></i>
                      <p class="mt-2 mb-0 small fw-bold text-truncate" style="max-width:150px;" title="<%= doc.original_name %>"><%= doc.original_name %></p>
                    </a>
                    <span class="small text-muted"><%= (doc.filesize / 1024).toFixed(1) %> KB</span>
                    <span class="small text-muted"><%= doc.uploader_name || 'Unknown' %></span>
                    <div class="mt-2 d-flex gap-1">
                      <a href="/documents/view/<%= doc.id %>" class="btn btn-sm btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                      <a href="/documents/download/<%= doc.id %>" class="btn btn-sm btn-outline-success" title="Download"><i class="bi bi-download"></i></a>
                      <form action="/documents/delete/<%= doc.id %>" method="POST" class="d-inline" onsubmit="return confirm('ลบไฟล์นี้?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>