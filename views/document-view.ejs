<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="d-flex position-relative">
  <%- include('partials/sidebar') %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <div class="main-content flex-grow-1 p-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h4 class="mb-0"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i><%= doc.original_name %></h4>
      <div class="d-flex gap-2">
        <a href="/documents" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
        <a href="/documents/download/<%= doc.id %>" class="btn btn-success btn-sm"><i class="bi bi-download"></i> Download</a>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-0" style="height:85vh;">
        <embed src="/documents/view/<%= doc.id %>/file" type="application/pdf" width="100%" height="100%" style="border:none;">
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>